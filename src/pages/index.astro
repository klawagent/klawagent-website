---
import {
  ArrowRight, Check, AtSign, Brain, Users, Puzzle, Globe, Database, Plus,
  Linkedin, Facebook, Instagram, MapPin
} from '@lucide/astro';
import StructuredData from '../components/StructuredData.astro';

const title = 'KlawAgent — AI without the IT · Early access';
const description = 'Hire your first AI employee. KlawAgent runs the boring stuff so you can focus on your business. Join the early-access waitlist.';
const canonicalURL = new URL('/', Astro.site);
const ogImage = '/og-image.jpg';
const year = new Date().getFullYear();

// Endpoint that receives the waitlist signup and forwards it to Resend.
// (Lives on the always-on Railway server; the static site posts to it cross-origin.)
const WAITLIST_ENDPOINT = 'https://klawagent-website-production.up.railway.app/api/waitlist';

const FEATURES = [
  { icon: AtSign,   label: 'Agent Email',           desc: 'Every agent gets its own inbox to send and receive.' },
  { icon: Brain,    label: 'Persistent Memory',     desc: 'Your agents get smarter with every task.' },
  { icon: Users,    label: 'Multi-Agent',           desc: 'Specialists that work in parallel.' },
  { icon: Puzzle,   label: 'Dynamic Skills',        desc: 'One skill, every scenario handled.' },
  { icon: Globe,    label: 'Web Browsing',          desc: 'Live research, straight from the source.' },
  { icon: Database, label: 'Built-in Integrations',   desc: '80+ data sources' },
];
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />
<link rel="icon" type="image/png" href="/logo.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#C8392B" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImage, Astro.site)} />
<meta property="og:site_name" content="KlawAgent" />
<meta property="og:locale" content="en_US" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
<meta name="twitter:site" content="@klawagent" />
<meta name="twitter:creator" content="@klawagent" />
<meta name="author" content="KlawAgent Team" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,500;0,600;0,700;1,500&display=swap" rel="stylesheet" />

<script is:inline src="https://cdn.tailwindcss.com"></script>
<script is:inline>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          'brand-red': '#C8392B',
          'brand-red-dark': '#A62E22',
          'brand-brown': '#7B6B58',
          'brand-black': '#1C1917',
          'brand-grey': '#F5F4F1',
          'brand-grey-dark': '#C8C2BA',
          'brand-grey-mid': '#9B9188',
          'surface-secondary': '#EFEDE9',
        },
        boxShadow: {
          'card': '0 1px 3px 0 rgb(0 0 0 / 0.06), 0 1px 2px -1px rgb(0 0 0 / 0.04)',
          'card-hover': '0 4px 12px 0 rgb(0 0 0 / 0.08), 0 2px 4px -1px rgb(0 0 0 / 0.06)',
          'hero': '0 24px 60px -20px rgb(28 25 23 / 0.18), 0 8px 20px -8px rgb(28 25 23 / 0.08)',
        },
        fontFamily: {
          sans: ['Inter', 'system-ui', 'sans-serif'],
          logo: ['Lora', 'Georgia', 'serif'],
        },
      },
    },
  };
</script>
<style is:inline>
  html, body { font-family: 'Inter', system-ui, sans-serif; -webkit-font-smoothing: antialiased; }
  body { background: #EFEDE9; color: #1C1917; }

  /* Subtle paper texture for warmth */
  .paper-bg {
    background-color: #EFEDE9;
    background-image:
      radial-gradient(at 20% 10%, rgba(200, 57, 43, 0.06) 0px, transparent 50%),
      radial-gradient(at 85% 90%, rgba(123, 107, 88, 0.08) 0px, transparent 50%),
      radial-gradient(at 50% 60%, rgba(200, 57, 43, 0.03) 0px, transparent 60%);
  }

  /* Pulse dot */
  @keyframes pulse-dot { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.4); opacity: 0.6; } }
  .pulse-dot { animation: pulse-dot 1.6s ease-in-out infinite; }

  /* CTA hover lift */
  .cta-lift { transform: translateY(0); }
  .cta-lift:hover { transform: translateY(-1px); box-shadow: 0 14px 30px -8px rgba(200, 57, 43, 0.55), 0 6px 12px -2px rgba(200, 57, 43, 0.3) !important; }

  /* Grain overlay */
  .grain::before {
    content: ""; position: fixed; inset: 0; pointer-events: none; opacity: 0.04; z-index: 1;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
  }
</style>

<StructuredData type="Organization" title={title} description={description} url={canonicalURL} image={ogImage} />
</head>
<body class="paper-bg grain min-h-screen">
  <div class="min-h-screen flex flex-col">

    <!-- Top nav -->
    <nav class="relative z-20 px-6 lg:px-12 py-5 flex items-center justify-between">
      <a href="#" class="flex items-center group">
        <span class="font-logo font-semibold text-[26px] tracking-tight text-brand-black group-hover:text-brand-red transition-colors">KlawAgent</span>
      </a>
      <div class="flex items-center gap-3">
        <span class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[13px] font-medium text-brand-brown border border-brand-grey-dark/60 bg-white/60">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-red pulse-dot"></span>
          Launching soon
        </span>
        <a href="#signup" class="flex items-center gap-1.5 bg-brand-black text-white px-4 py-2 rounded-lg text-base font-medium hover:bg-brand-brown transition-colors">
          Early access
          <ArrowRight size={16} />
        </a>
      </div>
    </nav>

    <main class="flex-1">

      <!-- Hero -->
      <section class="relative px-6 pt-8 pb-14 lg:pt-14 lg:pb-16">
        <div class="relative z-10 max-w-5xl mx-auto">
          <p class="text-center text-[14px] sm:text-[15px] font-medium text-brand-brown mb-5 tracking-wide">
            You shouldn't need a tech team to use AI.
          </p>

          <h1 class="font-logo font-semibold tracking-tight text-brand-black text-center leading-[1.02] text-[52px] sm:text-[68px] lg:text-[84px] mb-6">
            Hire your first <span class="italic text-brand-red">AI employee.</span>
          </h1>

          <p class="text-center text-[17px] sm:text-[19px] text-brand-brown max-w-[620px] mx-auto mb-9 leading-relaxed">
            KlawAgent runs the boring stuff so you can focus on your <span class="text-brand-black font-medium">business</span>.
          </p>

          <!-- Signup form -->
          <div class="w-full max-w-[520px] mx-auto" id="signup">
            <div id="waitlist-formwrap">
              <form id="waitlist-form" class="flex flex-col sm:flex-row gap-2.5" novalidate>
                <div class="relative flex-1">
                  <input
                    id="waitlist-email"
                    type="email"
                    inputmode="email"
                    autocomplete="email"
                    placeholder="you@company.com"
                    aria-label="Email address"
                    class="w-full rounded-xl bg-white px-4 py-3.5 text-[16px] text-brand-black placeholder-brand-grey-mid outline-none transition-all"
                    style="border: 1px solid rgba(123, 107, 88, 0.35); box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.05);"
                  />
                </div>
                <button
                  id="waitlist-btn"
                  type="submit"
                  class="cta-lift inline-flex items-center justify-center gap-2 bg-brand-red text-white px-6 py-3.5 rounded-xl text-[16px] font-semibold hover:bg-brand-red-dark transition-all disabled:opacity-60 disabled:cursor-not-allowed whitespace-nowrap"
                  style="box-shadow: 0 10px 24px -8px rgba(200, 57, 43, 0.45), 0 4px 8px -2px rgba(200, 57, 43, 0.25);"
                >
                  <span id="waitlist-btn-icon" class="inline-flex"><ArrowRight size={16} /></span>
                  Get early access
                </button>
              </form>
              <p id="waitlist-hint" class="mt-3 text-center text-[13px] text-brand-grey-mid">
                <span>Join the waitlist — be first in when we launch. No spam.</span>
              </p>
            </div>

            <!-- Success state (hidden until submit) -->
            <div
              id="waitlist-success"
              class="hidden rounded-2xl bg-white px-6 py-7 items-start gap-4"
              style="border: 1px solid rgba(200, 57, 43, 0.22); box-shadow: 0 24px 60px -20px rgba(200, 57, 43, 0.18), 0 8px 20px -8px rgba(123, 107, 88, 0.18);"
            >
              <div class="w-10 h-10 rounded-xl bg-brand-red flex items-center justify-center text-white flex-shrink-0">
                <Check size={20} strokeWidth={2.5} />
              </div>
              <div class="min-w-0">
                <p class="text-[17px] font-semibold text-brand-black mb-1">You're on the list.</p>
                <p class="text-[14.5px] text-brand-brown leading-relaxed">
                  We'll email <span id="waitlist-success-email" class="font-medium text-brand-black"></span> the moment early access opens. No spam — just the invite.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Key features -->
      <section class="relative w-full py-14 lg:py-20" style="background-color: #E8E4DC;">
        <div class="max-w-6xl mx-auto px-6">
          <div class="text-center mb-10">
            <div class="text-[11px] uppercase tracking-[0.18em] text-brand-grey-mid font-semibold mb-3">What's inside</div>
            <h2 class="font-logo font-semibold tracking-tight text-brand-black text-[30px] sm:text-[38px] leading-[1.12]">
              Everything an agent employee needs to work.
            </h2>
          </div>

          <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
            {FEATURES.map((f) => {
              const FeatureIcon = f.icon;
              return (
                <div class="group flex flex-col items-start text-left rounded-2xl bg-white border border-brand-grey-dark/50 p-5 transition-all hover:border-brand-red/30 hover:-translate-y-0.5 shadow-card hover:shadow-card-hover">
                  <div class="w-10 h-10 rounded-xl bg-brand-grey flex items-center justify-center text-brand-red mb-4 transition-colors group-hover:bg-brand-red group-hover:text-white">
                    <FeatureIcon size={20} />
                  </div>
                  <div class="text-[15.5px] font-semibold text-brand-black mb-1">{f.label}</div>
                  <div class="text-[13.5px] text-brand-brown leading-snug">{f.desc}</div>
                </div>
              );
            })}
          </div>

          <div class="flex justify-center mt-5">
            <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/60 border border-dashed border-brand-grey-dark/70 text-[14px] font-medium text-brand-brown">
              <span class="text-brand-red inline-flex"><Plus size={16} /></span>
              plus more on the way
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-brand-grey-dark/60 px-6 lg:px-12 py-12">
      <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
        <div>
          <a href="#" class="flex items-center mb-3">
            <span class="font-logo font-semibold text-[22px] tracking-tight text-brand-black">KlawAgent</span>
          </a>
          <p class="text-sm text-brand-brown max-w-[300px] leading-relaxed">
            AI without the IT. Built for the rest of us. Launching soon.
          </p>
        </div>

        <div class="flex items-center gap-2">
          <a href="#linkedin" aria-label="LinkedIn" class="w-9 h-9 rounded-md border border-brand-grey-dark/60 flex items-center justify-center text-brand-brown hover:text-brand-black hover:border-brand-black transition-colors"><Linkedin size={16} /></a>
          <a href="#facebook" aria-label="Facebook" class="w-9 h-9 rounded-md border border-brand-grey-dark/60 flex items-center justify-center text-brand-brown hover:text-brand-black hover:border-brand-black transition-colors"><Facebook size={16} /></a>
          <a href="#instagram" aria-label="Instagram" class="w-9 h-9 rounded-md border border-brand-grey-dark/60 flex items-center justify-center text-brand-brown hover:text-brand-black hover:border-brand-black transition-colors"><Instagram size={16} /></a>
        </div>
      </div>

      <div class="max-w-6xl mx-auto pt-8 mt-8 border-t border-brand-grey-dark/40 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 text-[12px] text-brand-grey-mid">
        <div>© {year} KlawAgent</div>
        <div class="flex items-center gap-1.5">
          <MapPin size={14} />
          Built in Austin, TX
        </div>
      </div>
    </footer>

  </div>

  <script is:inline define:vars={{ WAITLIST_ENDPOINT }}>
    (function () {
      var form = document.getElementById('waitlist-form');
      var input = document.getElementById('waitlist-email');
      var hint = document.getElementById('waitlist-hint');
      var formwrap = document.getElementById('waitlist-formwrap');
      var success = document.getElementById('waitlist-success');
      var successEmail = document.getElementById('waitlist-success-email');
      var btn = document.getElementById('waitlist-btn');
      var btnIcon = document.getElementById('waitlist-btn-icon');
      if (!form) return;

      var ARROW = btnIcon ? btnIcon.innerHTML : '';
      var SPINNER = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
      var submitting = false;

      function setHintDefault() {
        hint.innerHTML = '<span>Join the waitlist — be first in when we launch. No spam.</span>';
        input.style.border = '1px solid rgba(123, 107, 88, 0.35)';
      }
      function setHintError(msg) {
        hint.innerHTML = '<span class="text-brand-red font-medium">' + msg + '</span>';
        input.style.border = '1px solid #C8392B';
      }

      input.addEventListener('input', function () { if (!submitting) setHintDefault(); });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var value = (input.value || '').trim();
        var valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
        if (!valid) { setHintError('Please enter a valid email address.'); input.focus(); return; }

        submitting = true;
        btn.disabled = true;
        if (btnIcon) btnIcon.innerHTML = SPINNER;

        fetch(WAITLIST_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: value, source: 'klawagent.ai' })
        })
        .then(function (r) { if (!r.ok) throw new Error('request failed'); return r; })
        .then(function () {
          if (successEmail) successEmail.textContent = value;
          formwrap.classList.add('hidden');
          success.classList.remove('hidden');
          success.classList.add('flex');
        })
        .catch(function () {
          submitting = false;
          btn.disabled = false;
          if (btnIcon) btnIcon.innerHTML = ARROW;
          setHintError('Something went wrong — please try again.');
        });
      });
    })();
  </script>
</body>
</html>
